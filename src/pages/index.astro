---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sree Pulikkal Vishwanagayakshi Temple | Authentic Naga Worship">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-eyebrow">Sree Pulikkal Vishwanagayakshi Temple</div>
      <h1 class="hero-title">Sacred Abode of the Divine Nagas</h1>
      <p class="hero-subtitle">
        Experience the divine grace of Vishwanagayakshiamma, Nagaraja, and Sarpayakshiamma. An unbroken lineage of authentic Vedic rituals on the sacred land of Kashyapa Maharshi.
      </p>
      <div class="hero-ctas">
        <a href="/poojas" class="btn btn-primary">Book Sacred Rituals</a>
      </div>
    </div>
  </section>

  <!-- Authority Bar -->
  <section class="authority-bar">
    <div class="authority-container">
      <div class="authority-item">
        <svg class="authority-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
        <div class="authority-text">Swayambhu<br><span>Self-manifested deity</span></div>
      </div>
      <div class="authority-item">
        <svg class="authority-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/>
        </svg>
        <div class="authority-text">Unbroken Lineage<br><span>Generations of sacred worship</span></div>
      </div>
      <div class="authority-item">
        <svg class="authority-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22v-6"/><path d="M12 8v8"/><path d="M7 13s1.5-2 5-2 5 2 5 2"/><path d="M7 18s1.5-2 5-2 5 2 5 2"/><path d="M12 8c-2.5 0-4-2.5-4-5 0-2 1.5-3 4-3s4 1 4 3c0 2.5-1.5 5-4 5z"/>
        </svg>
        <div class="authority-text">Seven Kavus<br><span>Protected naga groves</span></div>
      </div>
      <div class="authority-item">
        <svg class="authority-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 21h18"/><path d="M9 8h10"/><path d="M9 12h10"/><path d="M9 16h10"/><path d="M5 4v16"/><path d="M5 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v16"/>
        </svg>
        <div class="authority-text">Kashyapa Maharshi<br><span>Samadhi site &amp; sacred land</span></div>
      </div>
    </div>
  </section>

  <!-- Sacred Offerings -->
  <section class="offerings-section">
    <div class="section-header">
      <h2>Sacred Offerings</h2>
      <p>Authentic Vedic rituals performed to restore spiritual harmony and bestow divine blessings.</p>
    </div>
    <div class="offerings-grid">
      <div class="offering-card">
        <a href="/poojas/ayilyam" class="card-overlay" aria-label="Ayilyam Pooja"></a>
        <div class="offering-image">
          <img src="/images/Ayiliyam.png" alt="Ayilyam Pooja">
        </div>
        <div class="offering-content">
          <span class="offering-badge">Monthly Ritual</span>
          <h3>Ayilyam Pooja</h3>
          <p>Performed monthly on the Ayilyam Nakshathra for economic prosperity, family harmony, and the protection of children.</p>
          <div class="offering-footer">
            <a href="https://forms.gle/C3eQViaTHURBS48v7" class="offering-cta" target="_blank" rel="noopener">Enquire</a>
          </div>
        </div>
      </div>

      <div class="offering-card">
        <a href="/poojas/navagraha-homam" class="card-overlay" aria-label="Navagraha Homam"></a>
        <div class="offering-image">
          <img src="/images/Navagraha%20Homam.jpg" alt="Navagraha Homam">
        </div>
        <div class="offering-content">
          <span class="offering-badge">Special Event</span>
          <h3>Navagraha Homam</h3>
          <p>A powerful ritual to pacify adverse planetary placements and remove unseen obstacles from your path.</p>
          <div class="offering-footer">
            <a href="https://forms.gle/C3eQViaTHURBS48v7" class="offering-cta" target="_blank" rel="noopener">Enquire</a>
          </div>
        </div>
      </div>

      <div class="offering-card">
        <a href="/poojas/kala-sarpa-bali" class="card-overlay" aria-label="Kala Sarpa Bali"></a>
        <div class="offering-image">
          <img src="/images/Kala%20sarppabali%20pooja.jpeg" alt="Kala Sarpa Bali">
        </div>
        <div class="offering-content">
          <span class="offering-badge">Annual Event</span>
          <h3>Kala Sarpa Bali</h3>
          <p>Our intensive annual Maha-remedy, specifically performed to neutralize the severe effects of Kala Sarpa Dosha.</p>
          <div class="offering-footer">
            <a href="https://forms.gle/C3eQViaTHURBS48v7" class="offering-cta" target="_blank" rel="noopener">Enquire</a>
          </div>
        </div>
      </div>

      <div class="offering-card">
        <a href="/muttu" class="card-overlay" aria-label="Muttu"></a>
        <div class="offering-image">
          <img src="/images/Payasa%20Bali.jpg" alt="Muttu Offering">
        </div>
        <div class="offering-content">
          <span class="offering-badge">Obstacle Removal</span>
          <h3>Muttu</h3>
          <p>Sacred coconut-breaking ritual where Ambotti Thampuran reveals and resolves your life&#8217;s obstacles through divine guidance.</p>
          <div class="offering-footer">
            <a href="/muttu" class="offering-cta">Learn More</a>
          </div>
        </div>
      </div>

      <div class="offering-card">
        <a href="/poojas/pratyangira-homam" class="card-overlay" aria-label="Maha Pratyangira Homam"></a>
        <div class="offering-image">
          <img src="/images/Mahaprathyangari%20homam1.jpeg" alt="Maha Pratyangira Homam">
        </div>
        <div class="offering-content">
          <span class="offering-badge">Powerful Remedy</span>
          <h3>Maha Pratyangira Homam</h3>
          <p>An intense Shakti ritual invoking Goddess Maha Pratyangira to destroy negative energies, black magic, and evil eye afflictions.</p>
          <div class="offering-footer">
            <a href="https://forms.gle/C3eQViaTHURBS48v7" class="offering-cta" target="_blank" rel="noopener">Enquire</a>
          </div>
        </div>
      </div>

      <div class="offering-card">
        <a href="/poojas/guruthi-pooja" class="card-overlay" aria-label="Maha Guruthi Pooja"></a>
        <div class="offering-image">
          <img src="/images/Maha%20Guruthi%20Pooja.jpeg" alt="Maha Guruthi Pooja">
        </div>
        <div class="offering-content">
          <span class="offering-badge">Sacred Offering</span>
          <h3>Maha Guruthi Pooja</h3>
          <p>A traditional blood-substitute offering made with turmeric and lime, performed to fulfil vows and invoke the blessings of Naga devatas.</p>
          <div class="offering-footer">
            <a href="https://forms.gle/C3eQViaTHURBS48v7" class="offering-cta" target="_blank" rel="noopener">Enquire</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Naga Dosha -->
  <section class="text-section">
    <div class="text-container">
      <h2>Understanding Naga Dosha</h2>
      <p>
        Often, recurring obstacles in our lives&#8212;whether delays in marriage, difficulties in starting a family, persistent health issues, or sudden financial blocks&#8212;have deeper spiritual roots. For centuries, our tradition has recognized these patterns as imbalances requiring divine intervention rather than merely worldly solutions.
      </p>
    </div>
  </section>

  <!-- Guardian Section -->
  <section class="guardian-section">
    <div class="guardian-grid">
      <div class="guardian-image">
        <img src="/images/Ambotti.jpg" alt="Ambotti Thampuran">
      </div>
      <div class="guardian-content">
        <h2>Sacred Guardianship</h2>
        <p>
          Veeraporkkali Dasan Ambotti Thampuran leads the Shankarodath Kovilakam Trust with a singular vision to preserve and restore the sacred naga worship traditions of Kerala.
        </p>
        <blockquote class="guardian-quote">
          &#8220;The goal of this trust is to take over and preserve all the Kavus which are in a dilapidated condition, restore them to their original beauty, and bring out their glory to all people.&#8221;
        </blockquote>
        <a href="/support" class="btn-outline-dark">Support Kavu Preservation</a>
      </div>
    </div>
  </section>

  <!-- Temple Protocols -->
  <section class="protocols-section">
    <div class="protocols-container">
      <h2>Temple Protocols</h2>
      <p>
        To maintain the deep spiritual potency of the rituals, we strictly adhere to traditional purity guidelines. Please review our protocols regarding dietary restrictions and mourning periods before scheduling your poojas.
      </p>
      <a href="/protocols" class="btn-outline-light">Read Guidelines</a>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(to bottom, rgba(45, 24, 16, 0.6), rgba(122, 25, 18, 0.88)),
      url('/images/temple%20main%20entrance.jpg') center/cover;
    background-color: var(--laterite-dark);
    padding: 8rem 2rem 4rem;
    text-align: center;
    border-bottom: 8px solid var(--saffron);
  }

  .hero-content {
    max-width: 900px;
    position: relative;
    z-index: 10;
  }

  .hero-eyebrow {
    font-family: 'Source Serif 4', serif;
    font-size: 1.05rem;
    color: var(--gold-light);
    text-transform: uppercase;
    letter-spacing: 6px;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .hero-title {
    font-size: 5rem;
    font-weight: 700;
    color: var(--bg-base);
    margin-bottom: 1.5rem;
    line-height: 1.1;
    text-shadow: 0px 4px 20px rgba(0, 0, 0, 0.8);
  }

  .hero-subtitle {
    font-size: 1.35rem;
    color: var(--bg-alt);
    margin-bottom: 3.5rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    font-style: italic;
    opacity: 0.9;
  }

  .hero-ctas {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  /* Authority Bar */
  .authority-bar {
    background: var(--bg-base);
    padding: 3rem 2rem;
    border-bottom: 1px solid var(--border-light);
  }

  .authority-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .authority-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.5rem;
    border: 1px solid var(--border-light);
    background: var(--bg-alt);
    box-shadow: inset 0 0 20px rgba(122, 25, 18, 0.03);
    border-bottom: 4px solid var(--laterite-red);
  }

  .authority-icon {
    width: 45px;
    height: 45px;
    color: var(--saffron);
    margin-bottom: 1.2rem;
  }

  .authority-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--laterite-red);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .authority-text span {
    display: block;
    font-family: 'Source Serif 4', serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    text-transform: none;
    font-style: italic;
  }

  /* Offerings */
  .offerings-section {
    padding: 6rem 2rem;
  }

  .offerings-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 3rem;
  }

  .offering-card {
    background: var(--bg-base);
    border: 1px solid var(--border-light);
    padding: 0.8rem;
    box-shadow: 0px 10px 30px rgba(122, 25, 18, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    position: relative;
  }

  .offering-card:hover {
    transform: translateY(-8px);
    box-shadow: 0px 15px 40px rgba(122, 25, 18, 0.15);
    border-color: var(--saffron);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .offering-image {
    width: 100%;
    height: 280px;
    overflow: hidden;
    border: 1px solid var(--border-light);
  }

  .offering-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(0.3) saturate(1.1) brightness(0.95);
    transition: transform 0.6s ease;
  }

  .offering-card:hover .offering-image img {
    transform: scale(1.05);
  }

  .offering-content {
    padding: 2rem 1.5rem 1.5rem;
    text-align: center;
    background: var(--bg-alt);
    margin-top: 0.8rem;
  }

  .offering-badge {
    display: inline-block;
    font-family: 'Source Serif 4', serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--saffron);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--saffron);
    padding-bottom: 4px;
  }

  .offering-content h3 {
    font-size: 2.2rem;
    color: var(--laterite-dark);
    margin-bottom: 1rem;
  }

  .offering-content > p {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .offering-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-light);
  }

  .offering-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--laterite-red);
  }

  .offering-cta {
    background: transparent;
    color: var(--laterite-red);
    border: 1px solid var(--laterite-red);
    padding: 0.7rem 1.8rem;
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    z-index: 2;
  }

  .offering-cta:hover {
    background: var(--laterite-red);
    color: var(--bg-base);
  }

  /* Naga Dosha */
  .text-section {
    padding: 6rem 2rem;
    background: var(--bg-alt);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    text-align: center;
  }

  .text-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .text-container h2 {
    font-size: 3.2rem;
    margin-bottom: 1.5rem;
    color: var(--laterite-dark);
  }

  .text-container p {
    font-size: 1.2rem;
    color: var(--text-muted);
    line-height: 1.9;
  }

  /* Guardian */
  .guardian-section {
    padding: 7rem 2rem;
    background: var(--bg-base);
  }

  .guardian-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .guardian-image img {
    width: 100%;
    border: 1px solid var(--border-light);
    padding: 12px;
    background: var(--bg-alt);
    filter: sepia(0.2) brightness(0.95);
    box-shadow: 0px 15px 40px rgba(122, 25, 18, 0.1);
  }

  .guardian-content h2 {
    font-size: 3.2rem;
    margin-bottom: 1.5rem;
    color: var(--laterite-red);
  }

  .guardian-content > p {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .guardian-quote {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-style: italic;
    color: var(--saffron);
    line-height: 1.6;
    padding: 2rem 0;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    margin: 2rem 0;
  }

  .btn-outline-dark {
    display: inline-block;
    margin-top: 1rem;
    padding: 1rem 2.5rem;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    color: var(--bg-base);
    background: var(--laterite-red);
    border: 2px solid var(--laterite-red);
    transition: all 0.3s ease;
  }

  .btn-outline-dark:hover {
    background: var(--bg-base);
    color: var(--laterite-red);
  }

  /* Protocols */
  .protocols-section {
    padding: 6rem 2rem;
    background: var(--laterite-dark);
    color: var(--bg-base);
    text-align: center;
    border-top: 8px solid var(--saffron);
    background-image: url('data:image/svg+xml;utf8,<svg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"><g fill="%23e67e00" fill-opacity="0.05" fill-rule="evenodd"><path d="M0 40L40 0H20L0 20M40 40V20L20 40"/></g></svg>');
  }

  .protocols-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .protocols-container h2 {
    color: var(--gold-light);
    margin-bottom: 1.5rem;
    font-size: 3rem;
  }

  .protocols-container p {
    font-size: 1.1rem;
    opacity: 0.9;
  }

  .btn-outline-light {
    display: inline-block;
    margin-top: 2rem;
    padding: 1rem 2.5rem;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    color: var(--laterite-dark);
    background: var(--gold-light);
    border: 2px solid var(--gold-light);
    transition: all 0.3s ease;
  }

  .btn-outline-light:hover {
    background: transparent;
    color: var(--gold-light);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .authority-container {
      grid-template-columns: repeat(2, 1fr);
    }

    .guardian-grid {
      grid-template-columns: 1fr;
    }

    .hero-title {
      font-size: 3rem;
    }
  }

  @media (max-width: 600px) {
    .offerings-grid {
      grid-template-columns: 1fr;
    }

    .authority-container {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
