}

.pooja-tagline {
  font-size: 1.35rem;
  color: var(--bg-alt);
  margin-bottom: 3rem;
}

.pooja-quick-info {
  display: flex;
  gap: 2rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 3rem;
  padding: 1.8rem 2rem;
  background: rgba(255,255,255,0.1);
