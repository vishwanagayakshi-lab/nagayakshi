---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Plan Your Visit | Sree Pulikkal Vishwanagayakshi Temple">
  
  <!-- Hero -->
  <section class="visit-hero">
    <div class="visit-hero-overlay"></div>
    <div class="visit-hero-content">
      <h1>Plan Your Visit</h1>
      <p>Everything you need to know before visiting the sacred Vishwanagayakshi Temple</p>
    </div>
  </section>

  <!-- Darshan Timings -->
  <section class="timings-section">
    <div class="visit-container">
      <div class="section-header">
        <h2>Darshan Timings</h2>
        <p class="section-note">Open all days of the year</p>
      </div>
      
      <div class="timings-grid">
        <div class="timing-card temple">
          <div class="timing-icon">🕉️</div>
          <h3>Temple Darshan</h3>
          <div class="timing-slots">
            <div class="slot">
              <span class="slot-label">Morning</span>
              <span class="slot-time">5:30 AM - 10:30 AM</span>
            </div>
            <div class="slot">
              <span class="slot-label">Evening</span>
              <span class="slot-time">5:30 PM - 7:30 PM</span>
            </div>
          </div>
          <p class="timing-note">Main temple sanctum for deity darshan</p>
        </div>
        
        <div class="timing-card kavu">
          <div class="timing-icon">🌳</div>
          <h3>Kavu (Grove) Access</h3>
          <div class="timing-slots">
            <div class="slot">
              <span class="slot-label">Throughout Day</span>
              <span class="slot-time">5:30 AM - 6:00 PM</span>
            </div>
          </div>
          <p class="timing-note">Visit all seven sacred Sarpa Kavus for prayers</p>
        </div>
      </div>
      
      <div class="timing-important">
        <h4>⚠️ Important Notes</h4>
        <ul>
          <li>Timings may vary on special occasions and festival days</li>
          <li>Major poojas are performed during morning hours (6:00-9:00 AM)</li>
          <li>Ayilyam poojas start early morning on Ayilyam Nakshathra days</li>
          <li>Temple may be closed temporarily for special ceremonies - call ahead if traveling from far</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- How to Reach -->
  <section class="directions-section">
    <div class="visit-container">
      <div class="section-header">
        <span class="section-label">Getting Here</span>
        <h2>How to Reach the Temple</h2>
      </div>
      
      <div class="address-card">
        <h3>Temple Address</h3>
        <div class="address-content">
          <p class="address-name">Pulikkal Shankarodath Kovilakam</p>
          <p class="address-details">
            Door No 13/444<br>
            Puduppariyaram Grama Panchayath<br>
            Thekkumpuram, Kavilpad, Olavakkode<br>
            Palakkad District - 678012<br>
            Kerala, India
          </p>
          <div class="address-actions">
            <a href="https://maps.google.com/?q=Pulikkal+Shankarodath+Kovilakam+Palakkad" target="_blank" class="btn-map">
              📍 Open in Google Maps
            </a>
            <a href="tel:+919946373522" class="btn-call">
              📞 Call for Directions
            </a>
          </div>
        </div>
      </div>
      
      <div class="transport-grid">
        <div class="transport-card">
          <div class="transport-icon">✈️</div>
          <h3>By Air</h3>
          <div class="transport-details">
            <p><strong>Nearest Airport:</strong> Coimbatore International Airport (CJB)</p>
            <p><strong>Distance:</strong> ~55 km (approx. 1.5 hours)</p>
            <p><strong>Taxi Fare:</strong> ₹1,200-1,500</p>
            <div class="transport-steps">
              <p><strong>How to reach from airport:</strong></p>
              <ol>
                <li>Exit Coimbatore Airport</li>
                <li>Take taxi/cab (pre-paid or app-based like Ola/Uber)</li>
                <li>Route: Coimbatore → Palakkad → Olavakkode</li>
                <li>Journey time: 1.5-2 hours depending on traffic</li>
              </ol>
            </div>
          </div>
        </div>
        
        <div class="transport-card">
          <div class="transport-icon">🚂</div>
          <h3>By Train</h3>
          <div class="transport-details">
            <p><strong>Nearest Station:</strong> Palakkad Junction (PGT)</p>
            <p><strong>Distance:</strong> ~8 km (approx. 20 minutes)</p>
            <p><strong>Auto/Taxi Fare:</strong> ₹150-250</p>
            <div class="transport-steps">
              <p><strong>Major trains to Palakkad:</strong></p>
              <ul>
                <li>From Chennai: Chennai-Alappuzha Express, Trivandrum Mail</li>
                <li>From Bangalore: Kochuveli Express, Island Express</li>
                <li>From Mumbai: Netravati Express</li>
                <li>From Delhi: Kerala Sampark Kranti Express</li>
              </ul>
              <p><strong>From station to temple:</strong> Auto-rickshaw or taxi available outside station</p>
            </div>
          </div>
        </div>
        
        <div class="transport-card">
          <div class="transport-icon">🚗</div>
          <h3>By Road</h3>
          <div class="transport-details">
            <p>Temple is well-connected by road from major cities</p>
            <div class="transport-steps">
              <p><strong>Driving distances:</strong></p>
              <ul>
                <li><strong>Coimbatore:</strong> 55 km (1.5 hours) via NH544</li>
                <li><strong>Thrissur:</strong> 85 km (2 hours) via NH544</li>
                <li><strong>Cochin:</strong> 130 km (3 hours) via NH544</li>
                <li><strong>Bangalore:</strong> 350 km (6 hours) via NH275</li>
                <li><strong>Calicut:</strong> 110 km (2.5 hours) via NH966</li>
              </ul>
              <p><strong>Google Maps:</strong> Search "Pulikkal Shankarodath Kovilakam" for turn-by-turn directions</p>
            </div>
          </div>
        </div>
        
        <div class="transport-card">
          <div class="transport-icon">🚌</div>
          <h3>By Bus</h3>
          <div class="transport-details">
            <p><strong>Nearest Bus Stand:</strong> Palakkad KSRTC Bus Stand</p>
            <p><strong>Distance:</strong> ~7 km from temple</p>
            <div class="transport-steps">
              <p><strong>Regular bus services from:</strong></p>
              <ul>
                <li>Coimbatore (every 30 mins)</li>
                <li>Thrissur (every hour)</li>
                <li>Cochin (multiple daily)</li>
                <li>Bangalore (overnight buses)</li>
              </ul>
              <p><strong>From bus stand:</strong> Local buses to Olavakkode or auto-rickshaw (₹100-150)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Accommodation -->
  <section class="accommodation-section">
    <div class="visit-container">
      <div class="section-header">
        <span class="section-label">Where to Stay</span>
        <h2>Accommodation Near Temple</h2>
        <p class="section-intro">Options for all budgets within 5-10 km of the temple</p>
      </div>
      
      <div class="accommodation-grid">
        <div class="accommodation-category">
          <h3>Budget Options (₹500-1,500/night)</h3>
          <div class="hotel-list">
            <div class="hotel-item">
              <h4>Lodge/Guest Houses in Olavakkode</h4>
              <p>Simple, clean rooms near temple area</p>
              <p class="hotel-distance">📍 2-3 km from temple</p>
            </div>
            <div class="hotel-item">
              <h4>KSRTC Yatri Nivas</h4>
              <p>Government-run lodge in Palakkad town</p>
              <p class="hotel-distance">📍 7 km from temple</p>
            </div>
          </div>
        </div>
        
        <div class="accommodation-category">
          <h3>Mid-Range Options (₹1,500-3,500/night)</h3>
          <div class="hotel-list">
            <div class="hotel-item">
              <h4>Hotels in Palakkad Town</h4>
              <p>Comfortable hotels with AC rooms and dining</p>
              <p class="hotel-distance">📍 7-10 km from temple</p>
              <p class="hotel-examples">Examples: Hotel Fort Palace, Hotel Indraprastha</p>
            </div>
            <div class="hotel-item">
              <h4>Budget Resorts near Malampuzha</h4>
              <p>Scenic locations with garden views</p>
              <p class="hotel-distance">📍 15 km from temple</p>
            </div>
          </div>
        </div>
        
        <div class="accommodation-category">
          <h3>Premium Options (₹3,500+/night)</h3>
          <div class="hotel-list">
            <div class="hotel-item">
              <h4>Kairali Heritage, Palakkad</h4>
              <p>Premium hotel with traditional Kerala architecture</p>
              <p class="hotel-distance">📍 10 km from temple</p>
            </div>
            <div class="hotel-item">
              <h4>Resorts in Coimbatore</h4>
              <p>Luxury resorts (if combining with other travel)</p>
              <p class="hotel-distance">📍 55 km from temple</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="accommodation-note">
        <h4>💡 Booking Tips</h4>
        <ul>
          <li>Book in advance during festival seasons (especially October-November for Kala Sarpa Bali)</li>
          <li>Contact temple for accommodation recommendations: +91 9946373522</li>
          <li>Many devotees prefer staying in Palakkad town (more options) and traveling to temple</li>
          <li>For budget stays near temple, call ahead - not all are listed online</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- First Time Visitor Guide -->
  <section class="visitor-guide-section">
    <div class="visit-container">
      <div class="section-header">
        <span class="section-label">First Time Visiting?</span>
        <h2>What to Expect</h2>
      </div>
      
      <div class="guide-grid">
        <div class="guide-card">
          <div class="guide-number">1</div>
          <h3>Arrival & Parking</h3>
          <ul>
            <li>Limited parking available near temple premises</li>
            <li>Auto-rickshaws can drop you at the entrance</li>
            <li>Remove footwear before entering temple compound</li>
            <li>Footwear stand available (free)</li>
          </ul>
        </div>
        
        <div class="guide-card">
          <div class="guide-number">2</div>
          <h3>Temple Entry</h3>
          <ul>
            <li>Enter with clean body and pure mind</li>
            <li>Men: Dhoti or traditional wear preferred (pants acceptable)</li>
            <li>Women: Saree or traditional Kerala dress preferred (salwar also fine)</li>
            <li>Photography inside sanctum is NOT allowed</li>
            <li>Mobile phones on silent mode</li>
          </ul>
        </div>
        
        <div class="guide-card">
          <div class="guide-number">3</div>
          <h3>Darshan Process</h3>
          <ul>
            <li>Proceed to main sanctum for deity darshan</li>
            <li>Offer your prayers silently</li>
            <li>You can offer flowers, coconut (available at temple counter)</li>
            <li>Priest will perform archana and give you prasadam</li>
            <li>Take prasadam with both hands, consume a small portion</li>
          </ul>
        </div>
        
        <div class="guide-card">
          <div class="guide-number">4</div>
          <h3>Visiting the Seven Kavus</h3>
          <ul>
            <li>After main temple darshan, visit the seven sacred Kavus</li>
            <li>Each Kavu has specific spiritual powers</li>
            <li>Offer prayers at each grove</li>
            <li>Respect the natural sanctity - do not pluck leaves or flowers</li>
            <li>The complete Kavu circuit takes 30-45 minutes</li>
          </ul>
        </div>
        
        <div class="guide-card">
          <div class="guide-number">5</div>
          <h3>Making Offerings</h3>
          <ul>
            <li>Offerings available at temple counter: coconuts, flowers, oil for lamps</li>
            <li>You can sponsor daily poojas or special abhishekam</li>
            <li>Donation box available for temple maintenance</li>
            <li>For booking specific poojas, contact the temple office</li>
          </ul>
        </div>
        
        <div class="guide-card">
          <div class="guide-number">6</div>
          <h3>Temple Etiquette</h3>
          <ul>
            <li>Maintain silence in sanctum area</li>
            <li>Don't touch the deity idols</li>
            <li>Follow priest's instructions during rituals</li>
            <li>Do not litter temple premises</li>
            <li>Show respect to other devotees</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Facilities -->
  <section class="facilities-section">
    <div class="visit-container">
      <div class="section-header">
        <h2>Temple Facilities</h2>
      </div>
      
      <div class="facilities-grid">
        <div class="facility-item">
          <div class="facility-icon">✅</div>
          <h4>Available</h4>
          <ul>
            <li>Parking space</li>
            <li>Footwear stand</li>
            <li>Drinking water</li>
            <li>Washrooms</li>
            <li>Pooja materials counter</li>
            <li>Prasadam distribution</li>
          </ul>
        </div>
        
        <div class="facility-item">
          <div class="facility-icon">❌</div>
          <h4>Not Available</h4>
          <ul>
            <li>Food/Meals (bring your own or eat before/after)</li>
            <li>Accommodation at temple</li>
            <li>ATM nearby (use in Palakkad town)</li>
            <li>Wi-Fi</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="visit-contact-section">
    <div class="visit-container">
      <div class="section-header">
        <h2>Need Help Planning Your Visit?</h2>
      </div>
      
      <div class="contact-grid">
        <div class="contact-card">
          <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <h3>Call Us</h3>
          <p class="contact-detail">+91 9946373522</p>
          <p class="contact-detail">+91 491 2552910</p>
          <p class="contact-note">Available during temple hours</p>
        </div>

        <div class="contact-card">
          <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <h3>Email Us</h3>
          <p class="contact-detail" style="font-size:1rem;">pulikkalvishwanagayakshitemple@gmail.com</p>
          <p class="contact-note">Response within 24 hours</p>
        </div>

        <div class="contact-card">
          <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          <h3>WhatsApp</h3>
          <p class="contact-detail">+91 9946373522</p>
          <p class="contact-note">For quick queries and directions</p>
        </div>
      </div>
      
      <div class="visit-cta">
        <a href="/protocols" class="btn btn-primary">Read Temple Protocols Before Visiting</a>
        <a href="/poojas" class="btn btn-primary">Book a Pooja Online</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* Visit Page Styles */
.visit-hero {
  position: relative;
  min-height: 50vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: 
    linear-gradient(rgba(82, 14, 9, 0.85), rgba(82, 14, 9, 0.85)),
    url('/images/temple.jpg') center/cover;
  padding: 8rem 2rem 4rem;
  text-align: center;
}

.visit-hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 50% 50%, rgba(212, 165, 116, 0.1) 0%, transparent 60%);
}

.visit-hero-content {
  max-width: 800px;
  position: relative;
  z-index: 10;
}

.visit-hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 4rem;
  font-weight: 700;
  color: white;
  margin-bottom: 1rem;
}

.visit-hero p {
  font-size: 1.3rem;
  color: var(--bg-alt);
  line-height: 1.6;
}

.visit-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* Sections */
.timings-section,
.directions-section,
.accommodation-section,
.visitor-guide-section,
.facilities-section,
.visit-contact-section {
  padding: 5rem 2rem;
}

.timings-section {
  background: var(--bg-base);
}

.directions-section {
  background: var(--bg-alt);
}

.accommodation-section {
  background: var(--bg-base);
}

.visitor-guide-section {
  background: var(--bg-alt);
}

.facilities-section {
  background: var(--bg-base);
}

.visit-contact-section {
  background: var(--laterite-dark);
  text-align: center;
}

.visit-contact-section .section-header h2 {
  color: var(--gold-light);
}

.section-header {
  text-align: center;
  margin-bottom: 3rem;
}

.section-label {
  display: inline-block;
  font-size: 0.9rem;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 3px;
  margin-bottom: 1rem;
  font-weight: 600;
}

.section-header h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3rem;
  font-weight: 700;
  color: var(--laterite-red);
  margin-bottom: 1rem;
}

.section-note {
  font-size: 1.1rem;
  color: var(--text-muted);
  font-style: italic;
}

.section-intro {
  font-size: 1.2rem;
  color: var(--text-muted);
  max-width: 700px;
  margin: 1rem auto 0;
}

/* Timings */
.timings-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2.5rem;
  margin-bottom: 3rem;
}

.timing-card {
  background: var(--bg-base);
  padding: 2.5rem;
  border-radius: 15px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
  border-top: 4px solid var(--laterite-red);
  text-align: center;
}

.timing-card.kavu {
  border-top-color: var(--gold);
}

.timing-icon {
  font-size: 3.5rem;
  margin-bottom: 1.5rem;
}

.timing-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--laterite-red);
  margin-bottom: 1.5rem;
}

.timing-slots {
  margin: 2rem 0;
}

.slot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.2rem;
  background: var(--bg-alt);
  border-radius: 10px;
  margin-bottom: 1rem;
}

.slot:last-child {
  margin-bottom: 0;
}

.slot-label {
  font-weight: 600;
  color: var(--text-muted);
  font-size: 1rem;
}

.slot-time {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--laterite-red);
}

.timing-note {
  color: var(--text-muted);
  font-size: 0.95rem;
  line-height: 1.6;
}

.timing-important {
  max-width: 900px;
  margin: 0 auto;
  background: linear-gradient(135deg, #fff9e6 0%, #fffaf0 100%);
  padding: 2rem;
  border-radius: 12px;
  border: 2px solid var(--gold);
}

.timing-important h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;
  color: var(--laterite-red);
  margin-bottom: 1rem;
}

.timing-important ul {
  margin: 0 0 0 1.5rem;
}

.timing-important li {
  margin-bottom: 0.8rem;
  line-height: 1.7;
}

/* Address & Transport */
.address-card {
  background: var(--bg-base);
  padding: 3rem;
  border-radius: 15px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
  margin-bottom: 3rem;
  border-left: 6px solid var(--laterite-red);
}

.address-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--laterite-red);
  margin-bottom: 1.5rem;
}

.address-name {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--laterite-dark);
  margin-bottom: 1rem;
}

.address-details {
  font-size: 1.1rem;
  color: var(--text-muted);
  line-height: 1.9;
  margin-bottom: 2rem;
}

.address-actions {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.btn-map,
.btn-call {
  padding: 1rem 2rem;
  border-radius: 2px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
  display: inline-block;
}

.btn-map {
  background: var(--laterite-red);
  color: white;
}

.btn-map:hover {
  background: var(--laterite-dark);
  transform: translateY(-3px);
}

.btn-call {
  background: var(--laterite-red);
  color: white;
}

.btn-call:hover {
  background: var(--saffron);
  transform: translateY(-3px);
}

.transport-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2.5rem;
}

.transport-card {
  background: var(--bg-base);
  padding: 2.5rem;
  border-radius: 15px;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

.transport-icon {
  font-size: 3rem;
  margin-bottom: 1.5rem;
}

.transport-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--laterite-red);
  margin-bottom: 1.5rem;
}

.transport-details p {
  margin-bottom: 1rem;
  line-height: 1.7;
}

.transport-details strong {
  color: var(--laterite-dark);
}

.transport-steps {
  margin-top: 1.5rem;
  padding-top: 1.5rem;
  border-top: 2px solid var(--bg-alt);
}

.transport-steps ol,
.transport-steps ul {
  margin: 1rem 0 0 1.5rem;
